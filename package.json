{
  "name": "bot-hospitality-2026",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npm run watch",
    "test": "node --test test/*.test.js && node --check src/monitor.js && node --check src/dashboard.js",
    "check": "node src/monitor.js --once --match M104 --cheapest-per-category",
    "watch": "node src/monitor.js --match M104 --cheapest-per-category --interval 60",
    "dashboard": "node src/dashboard.js",
    "list-dallas": "node src/monitor.js --once --venue NN_DAL",
    "db:migrate-state": "node scripts/migrate-state-to-postgres.mjs",
    "telegram:test": "node src/telegramTest.js",
    "telegram:updates": "node src/telegramTest.js updates",
    "service:status": "launchctl print gui/$(id -u)/com.matias.fifa-hospitality-monitor",
    "service:logs": "tail -n 80 /Users/matiasmassetti/.fifa-hospitality-monitor/.state/launchd.out.log /Users/matiasmassetti/.fifa-hospitality-monitor/.state/launchd.err.log",
    "service:stop": "launchctl bootout gui/$(id -u) /Users/matiasmassetti/Library/LaunchAgents/com.matias.fifa-hospitality-monitor.plist",
    "service:start": "launchctl bootstrap gui/$(id -u) /Users/matiasmassetti/Library/LaunchAgents/com.matias.fifa-hospitality-monitor.plist",
    "service:sync": "scripts/sync-runtime.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
